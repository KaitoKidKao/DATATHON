      "source": [
        "# VinUniversity Datathon 2026 - Advanced Final Solution\n",
        "* **Team:** Gridbreakers\n",
        "* **Approach:** 4-Level EDA + Recursive Forecasting with Promotion Calendar (LightGBM Ensemble)\n",
        "\n",
        "This notebook covers:\n",
        "1. **MCQ Solver** (Data-driven)\n",
        "2. **4-Level EDA** (Descriptive, Diagnostic, Predictive, Prescriptive)\n",
        "3. **Advanced Forecasting V4** (Recursive lags + Fourier features + Promotion Calendar)\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "import pandas as pd\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "import seaborn as sns\n",
        "import lightgbm as lgb\n",
        "from sklearn.metrics import mean_absolute_error, mean_squared_error, r2_score\n",
        "import warnings\n",
        "warnings.filterwarnings('ignore')\n",
        "\n",
        "# Plotting style\n",
        "plt.style.use('fivethirtyeight')\n",
        "sns.set_palette('husl')\n",
        "plt.rcParams['figure.figsize'] = (12, 6)\n",
        "np.random.seed(42)"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 1. Data Loading"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "import os\n",
        "base_path = 'datathon-2026-round-1/' # Change to './' if files are in root\n",
        "\n",
        "try:\n",
        "    orders = pd.read_csv(f'{base_path}orders.csv', parse_dates=['order_date'])\n",
        "    products = pd.read_csv(f'{base_path}products.csv')\n",
        "    returns = pd.read_csv(f'{base_path}returns.csv')\n",
        "    web_traffic = pd.read_csv(f'{base_path}web_traffic.csv', parse_dates=['date'])\n",
        "    order_items = pd.read_csv(f'{base_path}order_items.csv', low_memory=False)\n",
        "    customers = pd.read_csv(f'{base_path}customers.csv')\n",
        "    geography = pd.read_csv(f'{base_path}geography.csv')\n",
        "    sales = pd.read_csv(f'{base_path}sales.csv', parse_dates=['Date'])\n",
        "    payments = pd.read_csv(f'{base_path}payments.csv')\n",
        "    promotions = pd.read_csv(f'{base_path}promotions.csv', parse_dates=['start_date', 'end_date'])\n",
        "    inventory = pd.read_csv(f'{base_path}inventory.csv', parse_dates=['snapshot_date'])\n",
        "    sample_sub = pd.read_csv(f'{base_path}sample_submission.csv', parse_dates=['Date'])\n",
        "    print(\"All data loaded successfully.\")\n",
        "except Exception as e:\n",
        "    print(\"Warning: Path issue.\", e)"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "---\n",
        "## Part 1: MCQ Solver (Automated)\n",
        "Calculating answers directly from data for maximum precision."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "print(\"--- MCQ RESULTS ---\")\n",
        "# Q1: Inter-order gap\n",
        "ords_sorted = orders.sort_values(by=['customer_id', 'order_date'])\n",
        "ords_sorted['gap'] = (ords_sorted['order_date'] - ords_sorted.groupby('customer_id')['order_date'].shift(1)).dt.days\n",
        "print(f\"Q1 Median Gap: {ords_sorted['gap'].median()} days\")\n",
        "\n",
        "# Q2: Best Margin Segment\n",
        "products['margin'] = (products['price'] - products['cogs']) / products['price']\n",
        "print(f\"Q2 Best Segment: {products.groupby('segment')['margin'].mean().idxmax()}\")\n",
        "\n",
        "# Q3: Top Streetwear return reason\n",
        "ret_p = returns.merge(products, on='product_id')\n",
        "print(f\"Q3 Streetwear Reason: {ret_p[ret_p['category'] == 'Streetwear']['return_reason'].mode()[0]}\")\n",
        "\n",
        "# Q4: Lowest Bounce Source\n",
        "print(f\"Q4 Lowest Bounce: {web_traffic.groupby('traffic_source')['bounce_rate'].mean().idxmin()}\")\n",
        "\n",
        "# Q5: % Promo\n",
        "print(f\"Q5 % Promo: {round(order_items['promo_id'].notnull().mean()*100, 2)}%\")\n",
        "\n",
        "# Q6: Age group orders\n",
        "cust_ords = orders.groupby('customer_id').size().reset_index(name='c')\n",
        "cust_age = customers.merge(cust_ords, on='customer_id', how='left').fillna(0)\n",
        "print(f\"Q6 Best Age Group: {cust_age[cust_age['age_group'] != '0'].groupby('age_group')['c'].mean().idxmax()}\")\n",
        "\n",
        "# Q7: Top Region\n",
        "items_rev = order_items.copy()\n",
        "items_rev['revenue'] = items_rev['quantity'] * items_rev['unit_price']\n",
        "geo_rev = orders.merge(items_rev[['order_id','revenue']], on='order_id').merge(geography, on='zip')\n",
        "print(f\"Q7 Top Region: {geo_rev.groupby('region')['revenue'].sum().idxmax()}\")\n",
        "\n",
        "# Q8: Cancelled payment\n",
        "print(f\"Q8 Cancelled Payment: {orders[orders['order_status']=='cancelled']['payment_method'].mode()[0]}\")\n",
        "\n",
        "# Q9: Size return rate\n",
        "size_ret = returns.merge(products, on='product_id').groupby('size').size()\n",
        "size_ord = order_items.merge(products, on='product_id').groupby('size').size()\n",
        "print(f\"Q9 Top Size Return: {(size_ret/size_ord).idxmax()}\")\n",
        "\n",
        "# Q10: Installments\n",
        "print(f\"Q10 Best Installment: {payments.groupby('installments')['payment_value'].mean().idxmax()}\")"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "---\n",
        "## Part 2: Exploratory Data Analysis (EDA)\n",
        "### Level 1 & 2: Descriptive & Diagnostic"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "fig, axes = plt.subplots(1, 2, figsize=(16, 6))\n",
        "# Chart 1: Monthly Trend\n",
        "sales_m = sales.set_index('Date').resample('M')['Revenue'].sum().reset_index()\n",
        "sns.lineplot(data=sales_m, x='Date', y='Revenue', ax=axes[0])\n",
        "axes[0].set_title('Monthly Revenue (2012-2022)')\n",
        "\n",
        "# Chart 2: Regional Contribution\n",
        "region_rev = geo_rev.groupby('region')['revenue'].sum().sort_values()\n",
        "sns.barplot(x=region_rev.values, y=region_rev.index, ax=axes[1], palette='viridis')\n",
        "axes[1].set_title('Revenue by Region')\n",
        "plt.show()"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "### Level 3 & 4: Predictive & Prescriptive"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "plt.figure(figsize=(10, 6))\n",
        "inventory_agg = inventory.groupby(['category'])[['sell_through_rate', 'days_of_supply']].mean().reset_index()\n",
        "sns.scatterplot(data=inventory_agg, x='sell_through_rate', y='days_of_supply', hue='category', s=300)\n",
        "for i, txt in enumerate(inventory_agg.category): plt.annotate(txt, (inventory_agg.sell_through_rate[i], inventory_agg.days_of_supply[i]))\n",
        "plt.axhline(inventory_agg['days_of_supply'].mean(), color='r', linestyle='--')\n",
        "plt.axvline(inventory_agg['sell_through_rate'].mean(), color='r', linestyle='--')\n",
        "plt.title('Inventory Optimization Matrix')\n",
        "plt.show()"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "---\n",
        "## Part 3: Advanced Sales Forecasting (V4 Pipeline)\n",
        "Implementing recursive forecasting with a promotion calendar and seasonal Fourier features."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "TRAIN_END = pd.Timestamp('2022-12-31')\n",
        "\n",
        "# 1. Aggregate Web Traffic\n",
        "wt = web_traffic.groupby('date').agg({\n",
        "    'sessions': 'sum', 'page_views': 'sum', 'unique_visitors': 'sum', 'bounce_rate': 'mean', 'avg_session_duration_sec': 'mean'\n",
        "}).reset_index().rename(columns={'date': 'Date', 'unique_visitors': 'unique_vis', 'avg_session_duration_sec': 'avg_dur'})\n",
        "\n",
        "# 2. Promotion Calendar Extrapolation\n",
        "def get_promo_features(dates):\n",
        "    df = pd.DataFrame({'Date': dates})\n",
        "    m, d, yr = df.Date.dt.month, df.Date.dt.day, df.Date.dt.year\n",
        "    df['in_spring'] = ((m == 3) & (d >= 18) | (m == 4) & (d <= 17)).astype(int)\n",
        "    df['in_midyear'] = ((m == 6) & (d >= 23) | (m == 7) & (d <= 22)).astype(int)\n",
        "    df['in_yearend'] = ((m == 11) & (d >= 18) | (m == 12) | (m == 1) & (d <= 2)).astype(int)\n",
        "    df['days_to_end'] = df.Date.dt.days_in_month - d\n",
        "    df['is_last_week'] = (df['days_to_end'] <= 7).astype(int)\n",
        "    return df.drop(columns='Date')\n",
        "\n",
        "# 3. Feature Engineering\n",
        "def make_features(dates, history):\n",
        "    df = pd.DataFrame({'Date': dates})\n",
        "    # Calendar\n",
        "    df['month'], df['day'], df['dayofweek'], df['dayofyear'] = df.Date.dt.month, df.Date.dt.day, df.Date.dt.dayofweek, df.Date.dt.dayofyear\n",
        "    df['days_to_end'] = df.Date.dt.days_in_month - df['day']\n",
        "    # Fourier\n",
        "    for k in [1, 2]:\n",
        "        df[f'sin_m_{k}'] = np.sin(2*np.pi*k*df.day/30.5); df[f'cos_m_{k}'] = np.cos(2*np.pi*k*df.day/30.5)\n",
        "    # Lags\n",
        "    for lag in [1, 7, 30, 365]:\n",
        "        df[f'lag_{lag}'] = (df.Date - pd.Timedelta(days=lag)).map(history)\n",
        "    # Promo\n",
        "    df = pd.concat([df, get_promo_features(df.Date)], axis=1)\n",
        "    # Web\n",
        "    df = df.merge(wt, on='Date', how='left').fillna(0)\n",
        "    return df\n",
        "\n",
        "history = sales.set_index('Date')['Revenue']\n",
        "train_feat = make_features(sales['Date'], history)\n",
        "X, y = train_feat.drop(columns=['Date']), np.log1p(sales['Revenue'])\n",
        "\n",
        "# 4. Training (RMSE Loss Ensemble)\n",
        "model = lgb.LGBMRegressor(objective='rmse', learning_rate=0.02, n_estimators=1000, num_leaves=127, random_state=42, verbose=-1)\n",
        "model.fit(X, y)\n",
        "print(\"Model trained on full history.\")"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "### 4. Recursive Forecasting & Final Submission"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "print(\"Generating Recursive Forecasts...\")\n",
        "rolling_history = history.copy()\n",
        "test_dates = sample_sub['Date'].sort_values().tolist()\n",
        "preds = []\n",
        "\n",
        "for d in test_dates:\n",
        "    row = make_features(pd.Series([d]), rolling_history).drop(columns='Date')\n",
        "    p = float(np.expm1(model.predict(row)[0]))\n",
        "    rolling_history[d] = p\n",
        "    preds.append(p)\n",
        "\n",
        "# COGS Ratio Calculation\n",
        "cogs_ratio = (sales['COGS'] / sales['Revenue']).mean()\n",
        "sub = sample_sub.copy()\n",
        "sub['Revenue'] = preds\n",
        "sub['COGS'] = sub['Revenue'] * cogs_ratio\n",
        "sub['Date'] = sub['Date'].dt.strftime('%Y-%m-%d')\n",
        "sub.to_csv('submission.csv', index=False)\n",
        "print(\"Final submission.csv created!\")\n",
        "print(sub.head())"
      ]
    }
  ],\n",
